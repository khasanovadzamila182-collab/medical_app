generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         Int         @id @default(autoincrement())
  tgId       BigInt      @unique
  phone      String?
  subStatus  Boolean     @default(false)
  subUntil   DateTime?
  isAdmin    Boolean     @default(false)
  lastActive DateTime    @default(now())
  createdAt  DateTime    @default(now())
  children   Child[]
  logs       Log[]
  events     DiagEvent[]

  // New relation for the actively selected child in UI
  selectedChildId Int?
  selectedChild   Child? @relation("ActiveChild", fields: [selectedChildId], references: [id])

  notes          Note[]
  analysisFiles  AnalysisFile[]
  reminders      Reminder[]
}

model Child {
  id        Int      @id @default(autoincrement())
  name      String
  weight    Float
  ageMonths Int
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  activeUsers User[] @relation("ActiveChild")

  notes          Note[]
  analysisFiles  AnalysisFile[]
  reminders      Reminder[]

  @@index([userId])
}

model Log {
  id        Int      @id @default(autoincrement())
  userId    Int
  symptom   String
  action    String
  value     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model RedFlag {
  id       Int    @id @default(autoincrement())
  module   String
  trigger  String
  message  String
  severity String @default("danger")

  @@index([module])
}

model DiagEvent {
  id        Int      @id @default(autoincrement())
  userId    Int
  module    String
  eventType String   // "start" | "end" | "red_flag"
  step      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([module])
  @@index([createdAt])
}

model MediaLink {
  id       Int     @id @default(autoincrement())
  stepId   String  @unique
  imageUrl String
  caption  String?
}

model Note {
  id        Int      @id @default(autoincrement())
  userId    Int
  childId   Int
  text      String
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  child     Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([childId])
}

model AnalysisFile {
  id        Int      @id @default(autoincrement())
  userId    Int
  childId   Int
  fileName  String
  fileUrl   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  child     Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([childId])
}

model Reminder {
  id            Int      @id @default(autoincrement())
  userId        Int
  childId       Int
  type          String   // "time" (e.g., 40 mins) | "medication"
  title         String   // e.g., "Повторить замер" or "Нурофен 5мл"
  intervalHours Int?     // e.g., 8, 12, etc. (for recurring)
  nextAt        DateTime
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  child         Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([childId])
  @@index([nextAt])
}

